# Copy to .env and fill in.

# Wallet PK that owns the GMX account on settlement chain. Must have:
#  - USDC on Base (source) for bridge-in test
#  - ETH on Base for LayerZero nativeFee + gas
#  - some funds on Arbitrum for bridge-out
GMX_TEST_PRIVATE_KEY=0x...

# API instance with multichain endpoints (e.g. local gmx-api or staging)
GMX_TEST_API_URL=http://localhost:3004/v1

# Settlement chain RPC (Arbitrum). Required for classic submit flows.
GMX_TEST_RPC_URL=https://arb1.arbitrum.io/rpc

# Source chain RPC (Base). Required for wallet submit on the source chain
# (signer needs a transport even in the API-driven path).
# Public https://mainnet.base.org is rate-limited & flaky — prefer Alchemy/Infura:
#   https://base-mainnet.g.alchemy.com/v2/<key>
GMX_TEST_SOURCE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<key>

# Gates tests that actually broadcast a transaction.
GMX_TEST_SEND=1
